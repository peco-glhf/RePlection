{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RePlection",
  "version": "0.1.0",
  "identifier": "com.gemini-live.companion",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RePlection",
        "width": 380,
        "height": 520,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
